AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Strata API app registration (Entra ID). Used for JWT audience checks and
# MSAL sign-in in the browser. AZURE_CLIENT_ID is honored as a fallback for
# legacy local-dev .env files.
AZURE_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000
AZURE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
AZURE_REDIRECT_URI=http://localhost:8765/

# DefaultAzureCredential workload-identity hint. In Container Apps this is
# the user-assigned managed identity's clientId (set automatically by Bicep).
# Locally with `az login`, leave unset and the CLI credential is used.
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure SQL (Entra-only auth via DefaultAzureCredential).
# In Container Apps the workload's user-assigned managed identity is used.
# Locally, `az login` works because the same credential chain falls through to
# the Azure CLI. msodbcsql18 must be installed on the host (`brew install msodbcsql18`).
AZURE_SQL_SERVER=your-sql-server.database.windows.net
AZURE_SQL_DATABASE=strata
# Or set the full ODBC connection string (overrides the two values above):
# AZURE_SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:your-sql-server.database.windows.net,1433;Database=strata;Encrypt=yes;TrustServerCertificate=no;Authentication=ActiveDirectoryDefault;

AZURE_STORAGE_CONTAINER=firm-documents
# Production: managed identity + DefaultAzureCredential.
AZURE_STORAGE_ACCOUNT_URL=https://youraccount.blob.core.windows.net
# Local dev only: connection string fallback.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net

# App Insights connection string is injected by Container Apps in deployed envs.
# Set locally only if you want to ship traces from your laptop.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Optional: Document Intelligence (raw-file layout/read — used by workers / future routes).
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=...

# Hosted Azure OpenAI mode sends document excerpts to Azure OpenAI.
STRATA_AI_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=your-chat-deployment
AZURE_OPENAI_API_VERSION=2024-10-21

# Zero model-retention mode: run a local or tenant-hosted Ollama endpoint and set:
# STRATA_AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e4b

# Remote MinerU 3.x ``mineru-api`` (GPU host). REQUIRED for Strata to use a remote GPU: when unset,
# the app runs the ``mineru`` CLI on the same machine as uvicorn (often a laptop CPU — slow).
# Put this in the environment of the process that runs ``uvicorn app:app`` (not only your shell profile
# unless you export before starting the server). Docker/Container Apps need the same variable.
# Typical laptop: SSH tunnel then point at localhost.
# Example: ssh -L 8888:localhost:8000 user@gpu-host -N
# MINERU_API_URL=http://127.0.0.1:8888
# Optional: request timeout in seconds (large PDFs / VLM).
# MINERU_API_TIMEOUT=600
# Optional: comma-separated langs sent to the API (default en).
# MINERU_API_LANG_LIST=en

# Full-document MinerU for "Deep extract" (sidebar) and Excel export. Default is ``hybrid-auto-engine`` —
# MinerU picks per page: pipeline (fast OCR) for digital pages, VLM for scanned pages. Best mix of speed
# and accuracy across mixed-content docs and what the "Extract" button uses.
# Override only if you need a specific backend:
#   pipeline           — pure CPU OCR, fastest, weakest on scanned docs
#   vlm-auto-engine    — pure VLM in mineru-api's process (GPU required, slow without one)
#   hybrid-http-client — like hybrid-auto-engine but VLM is a separate server (see MINERU_SERVER_URL below)
#   vlm-http-client    — pure VLM via separate server
# MINERU_DEEP_BACKEND=hybrid-auto-engine

# Optional: split-process VLM (vlm-http-client / hybrid-http-client backends). When set, this URL is
# forwarded as the ``server_url`` form field on every /file_parse request, telling mineru-api to call an
# OpenAI-compatible inference server (vLLM, SGLang, llama-server, hosted OpenAI, …) instead of running
# the VLM in its own process. mineru-api ignores it for backends that don't use it, so it's safe to leave
# set even when the user picks pipeline / vlm-auto-engine.
#
# Resolved from ``mineru-api``'s host, NOT from this machine: e.g. http://127.0.0.1:30000 means port 30000
# on whatever box runs mineru-api. If vLLM and mineru-api live on the same GPU host, that's the right URL.
# If they're on different hosts, use whatever address mineru-api can reach.
#
# Typical GPU host setup (run both processes on the SAME machine):
#
#   # 1. vLLM serving the MinerU 2.5 weights on an OpenAI-compatible API:
#   python -m vllm.entrypoints.openai.api_server \
#     --model opendatalab/MinerU2.5-Pro-2604-1.2B \
#     --host 0.0.0.0 --port 30000
#
#   # 2. mineru-api in front of it. There is NO --backend or --vlm-server-url flag — backend selection
#   #    happens per-request. The only relevant launch flag for split-process mode is the security gate
#   #    --allow-public-http-client (required when binding to 0.0.0.0 / :: so *-http-client requests work):
#   mineru-api --host 0.0.0.0 --port 8000 --allow-public-http-client
#
# Then on this machine:
# MINERU_SERVER_URL=http://127.0.0.1:30000
# MINERU_DEEP_BACKEND=hybrid-http-client   # or vlm-http-client

MICROSOFT_GRAPH_DRIVE_ID=your-sharepoint-or-onedrive-drive-id
MICROSOFT_GRAPH_ROOT_FOLDER=Strata
# Optional app-only Graph export/import. If omitted, delegated browser Graph tokens are used when present.
MICROSOFT_GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_GRAPH_CLIENT_SECRET=your-client-secret
